# ASR backend: groq (Groq Whisper, default, free, no credit card) or azure
ASR_BACKEND=groq

# Groq Whisper (ASR) — free key at https://console.groq.com (API Keys → Create)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_ASR_MODEL=whisper-large-v3

# Azure Speech Service — OPTIONAL (only if ASR_BACKEND=azure, or Japanese TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=japaneast

# TTS Settings
TTS_VOICE=ja-JP-KeitaNeural
TTS_MAX_SPEED_RATIO=1.3

# Vietnamese TTS backend: lucylab or vbee (default)
TTS_BACKEND_VI=vbee

# Vietnamese TTS (LucyLab API) — used when TTS_BACKEND_VI=lucylab
VIETNAMESE_API_KEY=sk_live_your_key_here
VIETNAMESE_VOICEID_MALE=your_male_voice_id_here
VIETNAMESE_VOICEID_FEMALE=your_female_voice_id_here
LUCYLAB_API_URL=https://api.lucylab.io/json-rpc
VIETNAMESE_TTS_MAX_SPEED=1.3

# Vbee AIVoice (https://studio.vbee.vn -> Tích hợp API) — used when TTS_BACKEND_VI=vbee
# App ID + Token are both shown on the app detail page (the screenshot lists App ID only).
VBEE_APP_ID=your_vbee_app_id_here
VBEE_TOKEN=your_vbee_token_here
VBEE_API_URL=https://vbee.vn/api/v1/tts
VBEE_VOICE_MALE=n_hanoi_male_protrainer_education_vc
VBEE_VOICE_FEMALE=hn_female_ngochuyen_full_48k-fhg
VBEE_AUDIO_TYPE=mp3
VBEE_BITRATE=128
# Required by Vbee even though we poll for the result; dummy URL is fine.
VBEE_CALLBACK_URL=https://example.com/vbee-callback
# Audio speed adjustment (0.82 = 18% slower, 1.0 = no change)
AUDIO_SLOW_FACTOR=0.82

# Video Input
VIDEO_URL=https://youtube.com/watch?v=xxx

# General
DEFAULT_SOURCE_LANG=en-US
AUDIO_SAMPLE_RATE=16000
OUTPUT_DIR=./output

# Claude Code translate mode ("Claude tự động" in the GUI) — uses the installed
# `claude` CLI (subscription, no API key). All optional:
#   CLAUDE_DEFAULT_MODEL  model mặc định cho dropdown trong GUI: sonnet (mặc định,
#                         đỡ tốn quota) / haiku / opus. Đổi tự do ngay trên giao diện.
#   CLAUDE_MODEL_ID       ép một model id cố định (bỏ trống để dùng CLAUDE_DEFAULT_MODEL)
#   CLAUDE_BIN            full path to claude(.exe) if it isn't on PATH
#   CLAUDE_PERMISSION_MODE  headless write permission (default: acceptEdits)
CLAUDE_DEFAULT_MODEL=sonnet
CLAUDE_MODEL_ID=
CLAUDE_BIN=
CLAUDE_PERMISSION_MODE=acceptEdits

# Opencode translate mode ("Opencode tự động" in the GUI) — uses the installed
# `opencode` CLI (local AI agent). All optional:
#   OPENCODE_MODEL_ID     leave empty to use the CLI's default model
#   OPENCODE_BIN          full path to opencode(.exe) if it isn't on PATH
OPENCODE_MODEL_ID=
OPENCODE_BIN=
